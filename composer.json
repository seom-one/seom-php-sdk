{
    "name": "seom/sdk",
    "description": "Official PHP SDK for the Seom SEO Content Generation API",
    "type": "library",
    "license": "MIT",
    "keywords": ["seom", "seo", "content", "ai", "sdk"],
    "homepage": "https://seom.one",
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Seom\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Seom\\Sdk\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
